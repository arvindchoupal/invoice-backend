NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://invoicewala.shop
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=invoice_maker

# Optional: use these when DB_USER does not exist yet.
# The setup script creates DB_NAME, creates/grants DB_USER, then creates tables.
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=InvoiceWala <billing@invoicewala.shop>

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

UPLOAD_DIR=uploads
